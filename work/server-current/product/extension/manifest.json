{
  "manifest_version": 3,
  "name": "Can Rent Lah",
  "description": "给中国留学生的新加坡租房 AI 侧边栏。",
  "version": "0.1.0",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://www.propertyguru.com.sg/*",
    "http://localhost:8787/*",
    "http://101.47.73.151:8787/*",
    "https://app.canrentlah.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:8787/*",
        "http://101.47.73.151:8787/*",
        "https://app.canrentlah.com/*"
      ],
      "js": ["auth-sync.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.propertyguru.com.sg/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Can Rent Lah",
    "default_popup": "popup.html"
  }
}
