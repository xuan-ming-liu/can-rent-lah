{
  "manifest_version": 3,
  "name": "Can Rent Lah",
  "description": "给中国留学生用的新加坡租房 AI 侧边栏。",
  "version": "0.2.0",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.propertyguru.com.sg/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/gsap.min.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lib/ScrollTrigger.min.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lib/TextPlugin.min.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["auth-sync.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.propertyguru.com.sg/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Can Rent Lah",
    "default_popup": "popup.html"
  }
}
