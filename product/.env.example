# Can Rent Lah — 环境变量配置
# 复制此文件为 .env 并填上实际值
# cp .env.example .env

# ---------------------------------------------------------------------------
# 服务器
# ---------------------------------------------------------------------------
PORT=8787
NODE_ENV=production

# ---------------------------------------------------------------------------
# AI Provider（三选一）
# ---------------------------------------------------------------------------
# 默认: anthropic，可选: deepseek / openai
AI_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek（AI_PROVIDER=deepseek 时需要）
# DEEPSEEK_API_KEY=sk-...
# AI_MODEL=deepseek-chat

# OpenAI（AI_PROVIDER=openai 时需要）
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4.1-mini

# 通用 key（不推荐，用上面 provider 专属 key 更清晰）
# AI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# 激活码（逗号分隔，可选）
# ---------------------------------------------------------------------------
ACTIVATION_CODES=DEMO-PRO-2026,RENTLAH-TEST
